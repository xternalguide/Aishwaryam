								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firebaseIdToken\": \"YOUR_FIREBASE_ID_TOKEN\",\n    \"phoneNumber\": \"9000000010\",\n    \"deviceFingerprint\": \"postman_android_client\"\n}",
