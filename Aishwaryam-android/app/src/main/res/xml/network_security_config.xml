<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Deny cleartext/HTTP globally for production (default is false) -->
    <base-config cleartextTrafficPermitted="false" />

    <!-- Production Pinning for Aishwaryam API endpoints -->
    <domain-config>
        <domain includeSubdomains="true">api.aishwaryam.com</domain>
        <domain includeSubdomains="true">aishwaryam.com</domain>
        
        <pin-set expiration="2027-05-20">
            <!-- SHA-256 base64-encoded fingerprint for Aishwaryam API Primary Cert -->
            <pin digest="SHA-256">k2v657WOhwKUqh9ypPP53eJHReODDdB5+9vX/1spcAA=</pin>
            <!-- SHA-256 base64-encoded fingerprint for Backup/DR API Cert (Required by Android) -->
            <pin digest="SHA-256">gb8gb8gb8gb8gb8gb8gb8gb8gb8gb8gb8gb8gb8gb8g=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
