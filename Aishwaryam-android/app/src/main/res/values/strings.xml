    <string name="onboarding_save_future_title">Save Gold for\nYour Family\'s Future</string>
    <string name="onboarding_save_future_subtitle">Start as low as ₹100</string>
    <string name="onboarding_save_future_body">Gold is India\'s most trusted savings. Start your gold habit today — for weddings, children\'s future, or just growing wealth the traditional way.</string>
    <string name="onboarding_save_future_stat_label">to start saving</string>

    <string name="onboarding_secure_badge">100% SECURE</string>
    <string name="onboarding_secure_title">Your Gold is\nAlways Safe</string>
    <string name="onboarding_secure_subtitle">BIS-certified 91.6% pure 22K gold</string>
    <string name="onboarding_secure_body">Every gram you save is stored in secured, insured vaults. Your gold is 91.6% pure 22K — the same quality you\'d buy from a trusted jeweller.</string>
    <string name="onboarding_secure_stat_label">22K pure gold</string>

    <string name="onboarding_bonus_badge">EARN MORE GOLD</string>
    <string name="onboarding_bonus_title">Get Up to 7.5%\nBonus Gold</string>
    <string name="onboarding_bonus_subtitle">Earn extra gold on maturity</string>
    <string name="onboarding_bonus_body">The earlier you save, the more bonus gold you earn. Our tiered bonus system rewards consistent savers — bonus gold is credited upon successful completion of your plan.</string>
    <string name="onboarding_bonus_stat_label">bonus gold earned</string>

    <string name="onboarding_physical_badge">PHYSICAL REDEMPTION</string>
    <string name="onboarding_physical_title">Redeem Real Gold\nAnytime You Want</string>
    <string name="onboarding_physical_subtitle">Coins, bars, or jewellery</string>
    <string name="onboarding_physical_body">When your scheme matures, collect your gold as beautiful jewellery, coins, or bars at our stores — or have it delivered to your home.</string>
    <string name="onboarding_physical_stat_label">physical gold redeemable</string>
    <string name="ai_assistant_title">Aishwaryam @ Your Home Assistant</string>
    <string name="ai_assistant_subtitle">Always here to help</string>
    <string name="ai_greeting">Vanakkam! 🙏 I am your Aishwaryam jewellery savings assistant. How can I help you today?</string>
    <string name="qr_scheme_title">About Schemes</string>
    <string name="qr_scheme_response" formatted="false">We offer flexible gold savings plans starting from ₹100. Save over time, earn up to 7.5% bonus gold, and redeem as jewellery or coins upon maturity.</string>
    <string name="qr_bonus_title">Bonus Calculation</string>
    <string name="qr_bonus_response" formatted="false">Your bonus is calculated based on how early you save. For a 330-day scheme, you get 7.5% bonus for the first 75 days, gradually reducing to 1.5% towards maturity.</string>
    <string name="qr_safety_title">Gold Safety</string>
    <string name="qr_safety_response" formatted="false">Your gold is 100% safe. Every gram you save is backed by 22K 91.6% pure physical gold, insured and stored in secure vaults.</string>
    <string name="qr_redemption_title">How to Redeem</string>
    <string name="qr_redemption_response">After your scheme matures, you can redeem your accumulated gold as beautiful jewellery at any of our partner stores, or request delivery of coins/bars to your home.</string>
    <string name="qr_missed_title">Missed Savings Day</string>
    <string name="qr_missed_response">Don\'t worry! There are no strict penalties for missed savings. However, regular savings maximize your bonus rewards.</string>
    <string name="qr_kyc_title">KYC Help</string>
    <string name="qr_kyc_response">KYC is required for regulatory compliance. You can easily upload your PAN or Aadhaar card in the Profile section to complete verification.</string>
    <string name="qr_gst_title">GST Queries</string>
    <string name="qr_gst_response" formatted="false">A standard 3% GST is applicable when you convert your savings into physical gold (buying), as per government regulations.</string>
